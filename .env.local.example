# EmailJS credentials for the contact form (FinalCta section).
# Copy to .env.local and fill in from https://dashboard.emailjs.com
# All three are public-safe (client-side) keys.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Supabase (blog + admin panel). From your project's Settings → API.
# Both are public-safe; writes are protected by RLS + Supabase Auth.
# Setup: run supabase/schema.sql in the SQL Editor, create the public
# `blog-images` bucket, disable sign-ups, and add the admin user manually.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
